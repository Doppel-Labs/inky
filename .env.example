# Copy to .env and fill in. .env is gitignored.

# GitHub auth — pick ONE: a token (simplest) or a GitHub App (sturdier).
#
# (a) A token with read access to the org's repos — a fine-grained or classic PAT.
#     See docs/github-token-setup.md.
GITHUB_TOKEN=
#
# (b) A GitHub App installation (optional upgrade: no expiry, higher rate limits,
#     clean revoke). App ID is non-secret (config github.appId or here); the private
#     key is a secret — give it as a file path OR inline. The App wins if both a
#     token and an App are configured. See docs/github-app-setup.md.
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY_PATH=/etc/secrets/inky-app.private-key.pem
# GITHUB_APP_PRIVATE_KEY=     # inline PEM alternative (literal \n is accepted)

# LLM key for the AI summary (Phase 3+). Set the one matching config "provider".
# Only one is needed; without any, Inky uses the mechanical (no-AI) render.
#   provider "anthropic" (default, best quality):
ANTHROPIC_API_KEY=
#   provider "groq" (fast/cheap, open-weight models):
GROQ_API_KEY=
#   provider "openai" (OpenAI or any OpenAI-compatible endpoint via baseUrl):
OPENAI_API_KEY=

# Where the standup posts. Used by `inky serve` and `inky standup` (without
# --dry-run). Preferred over discord.webhookUrl in config — it's sensitive (anyone
# with this URL can post to your channel). Optional for dry runs.
DISCORD_WEBHOOK_URL=

# Bot token for the /standup slash command (Discord Developer Portal → your app →
# Bot → Reset Token). Secret. Only needed if you want on-demand /standup; the
# scheduled post needs only the webhook above. See docs/discord-bot-setup.md.
DISCORD_BOT_TOKEN=
