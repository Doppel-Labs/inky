# Copy to .env and fill in. .env is gitignored.

# GitHub token with read access to the org's repos.
# Self-host MVP: a classic PAT or fine-grained token. (Hosted tier later: a GitHub App.)
GITHUB_TOKEN=

# LLM key for the AI summary (Phase 3+). Set the one matching config "provider".
# Only one is needed; without any, Inky uses the mechanical (no-AI) render.
#   provider "anthropic" (default, best quality):
ANTHROPIC_API_KEY=
#   provider "groq" (fast/cheap, open-weight models):
GROQ_API_KEY=
#   provider "openai" (OpenAI or any OpenAI-compatible endpoint via baseUrl):
OPENAI_API_KEY=

# Where the standup posts. Used by `inky serve` and `inky standup` (without
# --dry-run). Preferred over discord.webhookUrl in config — it's sensitive (anyone
# with this URL can post to your channel). Optional for dry runs.
DISCORD_WEBHOOK_URL=

# Bot token for the /standup slash command (Discord Developer Portal → your app →
# Bot → Reset Token). Secret. Only needed if you want on-demand /standup; the
# scheduled post needs only the webhook above. See docs/discord-bot-setup.md.
DISCORD_BOT_TOKEN=
